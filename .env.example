# Copy to .env and adjust as needed. docker compose reads this file.

# --- Postgres ---
PG_HOST=db
PG_PORT=5432
PG_USER=app
PG_PASSWORD=app
PG_DB=municipal

# --- Embedding service ---
EMBEDDING_SERVICE_URL=http://embedder:8000
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIM=1024
EMBEDDING_QUERY_PROMPT_NAME=query

# --- Hybrid retrieval ---
# alpha: 1.0 = pure vector, 0.0 = pure lexical (BM25-style), 0.5 = balanced.
RETRIEVAL_ALPHA=0.5
# Hard switch for the vector arm. Set to false to run lexical-only search.
VECTOR_SEARCH_ENABLED=true
RRF_K=60
RETRIEVAL_TOP_K=5

# --- Appointments / slots ---
APPOINTMENT_DURATION_MINUTES=30
# Open weekdays, Monday=0 .. Sunday=6.
OFFICE_OPEN_DAYS=0,1,2,3,4
OFFICE_OPEN_TIME=09:00
OFFICE_CLOSE_TIME=12:30
BOOKING_TIMEZONE=Europe/Rome

# --- MCP server ---
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp
# Leave empty to disable auth. If set, Vapi must send: Authorization: Bearer <token>
MCP_AUTH_TOKEN=

# --- ngrok (used by the ngrok container only) ---
NGROK_AUTHTOKEN=

# --- Host ingestion script ---
# When running scripts/ingest.py from the host, point these at the published
# container ports instead of the in-compose hostnames.
# PG_HOST=localhost
# EMBEDDING_SERVICE_URL=http://localhost:8001
